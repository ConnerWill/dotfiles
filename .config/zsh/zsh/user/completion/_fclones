    (fclones)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:fclones-command-$line[1]:"
        case $line[1] in
            (group)
_arguments "${_arguments_options[@]}" : \
'-o+[Write the report to a file instead of the standard output]:PATH:_files' \
'--output=[Write the report to a file instead of the standard output]:PATH:_files' \
'-f+[Set output file format]:FORMAT:(default fdupes csv json)' \
'--format=[Set output file format]:FORMAT:(default fdupes csv json)' \
'-d+[Limit the recursion depth]:NUMBER:_default' \
'--depth=[Limit the recursion depth]:NUMBER:_default' \
'--transform=[Transform each file by the specified program before matching]:COMMAND:_default' \
'(--rf-under)-n+[Search for over-replicated files with replication factor above the specified value]:COUNT:_default' \
'(--rf-under)--rf-over=[Search for over-replicated files with replication factor above the specified value]:COUNT:_default' \
'(-n --rf-over)--rf-under=[Search for under-replicated files with replication factor below the specified value]:COUNT:_default' \
'-s+[Minimum file size in bytes (inclusive)]:BYTES:_default' \
'--min=[Minimum file size in bytes (inclusive)]:BYTES:_default' \
'--max=[Maximum file size in bytes (inclusive)]:BYTES:_default' \
